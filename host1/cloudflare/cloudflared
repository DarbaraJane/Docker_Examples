services:
  tunnel:
    image: cloudflare/cloudflared:latest
    container_name: cloudflare
    restart: unless-stopped
    networks:
      - traefik_proxy
    command: --no-autoupdate tunnel run --token ${CLOUDFLARE_TUNNEL_TOKEN} --protocol http2
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.cloudflare.rule=Host(`${URL}`)"
      - "traefik.http.routers.cloudflare.entrypoints=websecure"
      - "traefik.http.routers.cloudflare.tls.certresolver=<RESOLVER>"
      - "traefik.http.services.cloudflare.loadbalancer.server.port=${PORT}"

networks:
   traefik_proxy:
    name: traefik_proxy
    external: true
